# ─── General ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=3000
LOG_LEVEL=log
TRUST_PROXY=
APP_LANDING_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Databases ───────────────────────────────────────────────────────────────
PG_URI=postgresql://user:password@localhost:5432/kreeda
MONGODB_URI=mongodb://localhost:27017/kreeda
REDIS_URI=redis://localhost:6379
REDIS_KEY_PREFIX=kreeda:dev:
CACHE_DEFAULT_TTL=60

# ─── JWT ────────────────────────────────────────────────────────────────────
# RS256 key pair. Escape newlines as \n when storing in a single-line env var.
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Access token TTL — format: <number>MINUTE | <number>HOUR | <number>DAY
# Short-lived by design; clients rotate via /auth/refresh.
# Recommended: 15MINUTE
ACCESS_TOKEN_TTL=15MINUTE

# Sliding window: refresh token stops working if unused for this many days.
# Recommended: 30
REFRESH_TTL_DAYS=30

# Absolute ceiling: no session can outlive this, regardless of activity.
# Recommended: 90
ABSOLUTE_TTL_DAYS=90

# Grace period for refresh token rotation (seconds).
# How long the OLD refresh token stays valid after a new one is issued.
# Allows retries on slow networks without locking the user out.
# Must be between 5 and 300. Recommended: 30
REFRESH_TOKEN_GRACE_PERIOD_SECONDS=30

# ─── Google OAuth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── GCP / Storage ───────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCP_BUCKET_NAME=your-bucket-name
GCP_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GCP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
MEDIA_BASE_URL=https://storage.googleapis.com/your-bucket-name

# ─── OTP Auth ─────────────────────────────────────────────────────────────
OTP_HMAC_SECRET=change-me-to-a-strong-secret
# URL template — placeholders <<PHONE_NUMBER>> and <<OTP>> are substituted at runtime
SMS_GATEWAY_URL=https://your-sms-gateway/send?to=<<PHONE_NUMBER>>&msg=<<OTP>>
# Set to true in non-production envs to skip SMS dispatch and log OTP to console
OTP_DEV_MODE=true
# Optional: fix the OTP to a known value in dev (e.g. 000000)
OTP_DEV_FIXED_CODE=000000
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_SECONDS=60

# ─── LLM ─────────────────────────────────────────────────────────────────
LLM_ACTIVE_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ─── AI Coach ────────────────────────────────────────────────────────────
AI_COACH_ASSISTANT_NAME=Kreeda AI Coach
AI_COACH_ASSISTANT_TONE=motivating
AI_COACH_SESSION_TIMEOUT_MINUTES=30
AI_COACH_CONTEXT_MESSAGES=20

# RAZORPAY
RAZORPAY_KEY_ID = 'rzp_...'
RAZORPAY_KEY_SECRET = '...'
RAZORPAY_WEBHOOK_SECRET = '...'

# Internal service-to-service auth (HMAC-SHA256)
INTERNAL_HMAC_SECRET = '...'

# Video analysis service
VIDEO_ANALYSIS_SVC_BASE_URL = 'http://0.0.0.0:8000'
GCS_FRAMES_BUCKET_NAME = ''
